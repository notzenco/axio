{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Axio",
  "version": "0.0.1",
  "identifier": "sh.axio.desktop",
  "build": {
    "beforeDevCommand": "bun run dev:vite",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "bun run build:vite",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Axio",
        "width": 1440,
        "height": 900,
        "minWidth": 720,
        "minHeight": 560,
        "center": true,
        "decorations": false,
        "transparent": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost; style-src 'self'; script-src 'self'"
    }
  },
  "bundle": {
    "active": false
  }
}
