{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Axio",
  "version": "0.0.1",
  "identifier": "sh.axio.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Axio",
        "width": 1180,
        "height": 760,
        "minWidth": 820,
        "minHeight": 560,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost; style-src 'self'; script-src 'self'"
    }
  },
  "bundle": {
    "active": false
  }
}
